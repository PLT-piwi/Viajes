{
  "name": "comparador-viajes",
  "private": true,
  "version": "1.0.0",
  "description": "Comparador de gastos de viajes",
  "author": "Daniel",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.comparadorviajes.app",
    "productName": "Comparador de Viajes",
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": true,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["es_ES", "en_US"],
      "language": "3082"
    }
  }
}
